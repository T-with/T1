# ============================================================
# Phase 3 告警配置 — 追加到 .env
#
# 全部可选。不配置某个渠道就不会启用。
# ============================================================

# --- 告警最小级别: info / warning / critical ---
ALERT_MIN_SEVERITY=warning

# ============================================================
# 渠道 1: Telegram (最简单 — 5 分钟搞定)
# ============================================================
# 1. Telegram 搜 @BotFather,发 /newbot,按提示建 bot,拿到 token
# 2. 把 bot 加到群里(或私聊 bot 发一条消息)
# 3. 浏览器打开 https://api.telegram.org/bot<TOKEN>/getUpdates
#    找到 "chat":{"id":<数字>...} — 就是 chat_id
#    群的 chat_id 是负数,私聊的是正数
# 4. 填进下面
# ALERT_TELEGRAM_BOT_TOKEN=1234567:ABCdefGhIJklMnOpQrStUvWxYz
# ALERT_TELEGRAM_CHAT_ID=-1001234567890

# ============================================================
# 渠道 2: Webhook (飞书 / 钉钉 / Discord / Slack)
# ============================================================
# ALERT_WEBHOOK_TYPE 可选: feishu / dingtalk / discord / slack / generic

# --- 飞书群机器人 ---
# 群里右上角 -> 群机器人 -> 自定义机器人,拿到 webhook url
# ALERT_WEBHOOK_TYPE=feishu
# ALERT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# --- 钉钉群机器人 ---
# ALERT_WEBHOOK_TYPE=dingtalk
# ALERT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# --- Discord ---
# ALERT_WEBHOOK_TYPE=discord
# ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# --- Slack ---
# ALERT_WEBHOOK_TYPE=slack
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# ============================================================
# 渠道 3: SMTP 邮件
# ============================================================
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=you@gmail.com
# ALERT_SMTP_PASS=app_password_not_your_login_password
# ALERT_SMTP_FROM=you@gmail.com
# ALERT_SMTP_TO=your-alert-inbox@example.com,another@example.com

# ============================================================
# Grafana 访问凭据 (可选)
# ============================================================
# GRAFANA_USER=admin
# GRAFANA_PASS=请改默认密码
