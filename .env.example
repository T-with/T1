# MyTradingPlatform 环境变量

# Web 登录凭据（务必修改默认密码！）
ADMIN_USER=admin
ADMIN_PASS=changeme

# AI 配置（选一个填即可）
# === DeepSeek（推荐，便宜好用）===
AI_API_KEY=sk-your-deepseek-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

